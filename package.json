{
  "name": "studynotion",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c bgBlue,bgYellow \"npm --prefix client start\" \"npm --prefix server run dev\"",
    "build": "npm --prefix client run build",
    "test": "npm --prefix server run test",
    "docker:dev": "docker compose -f docker-compose.yml up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
